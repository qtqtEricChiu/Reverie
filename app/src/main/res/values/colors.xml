<resources>
    <!-- 原生 Splash 背景色：与默认深色配色对齐（#1C1B1F = BrandColors.Dark.background）。
         注意：原生 Splash 是静态 XML 色，无法引用 Compose 运行时莫奈动态色，
         故仅能对齐默认配色，莫奈取色在原生层做不到。 -->
    <color name="splash_bg">#1C1B1F</color>

    <!-- 深色主题色板（与 Compose BrandColors.Dark 同步） -->
    <color name="background_dark">#1C1B1F</color>
    <color name="surface_dark">#1C1B1F</color>
    <color name="primary_dark">#D0BCFF</color>
    <color name="secondary_dark">#CCC2DC</color>
    <color name="error_dark">#F2B8B5</color>
    <color name="on_background_dark">#E6E1E5</color>

    <!-- 浅色主题色板 -->
    <color name="background_light">#F8FAFC</color>
    <color name="surface_light">#FFFFFF</color>
    <color name="primary_light">#0F766E</color>
    <color name="secondary_light">#7C3AED</color>
    <color name="error_light">#DC2626</color>
    <color name="on_background_light">#0F172A</color>

    <!-- 语义色 -->
    <color name="success">#4ADE80</color>
    <color name="warning">#FBBF24</color>
    <color name="info">#38BDF8</color>
</resources>
